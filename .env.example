# === Discord ===
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# bot が反応するチャネルIDをカンマ区切りで指定する
# (空にした場合は全チャネルで動作する)
ALLOWED_CHANNEL_IDS=123456789012345678,234567890123456789

# 開発用ギルド(サーバー)ID
# 設定するとこのギルドにだけ Slash コマンドを同期する(即反映)
# 空にすると全ギルドへグローバル同期(反映まで最大1時間)
DEV_GUILD_ID=

# 結果の返信モード(コマンド引数 thread で個別に上書き可能)
#   inline  - コマンド実行チャネルに直接 Embed を返す (デフォルト)
#   thread  - スレッドを作成してその中に Embed を投稿する
RESPONSE_MODE=inline

# 自動 digest 投稿先のチャンネル ID
# 設定すると 4 時間ごと (timeframe=6h) と JST 0:00 (timeframe=24h) に自動投稿
# 空にすると自動投稿は無効 (/digest 手動コマンドのみ)
DIGEST_CHANNEL_ID=

# 自動 digest 投稿の個別 ON/OFF。 デフォは両方 OFF (手動 /digest のみ実行)。
# 復活させたいときに true に変更する。 DIGEST_CHANNEL_ID も併せて必要。
DIGEST_AUTO_4H_ENABLED=false
DIGEST_AUTO_DAILY_ENABLED=false

# digest 結果のアーカイブ用スレッド ID
# 設定すると /digest 実行と自動投稿の両方で、 1 ミーム 1 embed の形で
# このスレッドに追記する (DexScreener のバナー / アイコン付き)
DIGEST_ARCHIVE_THREAD_ID=

# === Smart Money roster (Helius 監視候補リスト) ===
# 1 日 1 回 /smart-money/dex-trades を叩いて wallet 一覧を sm_roster テーブルに蓄積する。
# 取得構成 (chain=solana, Fund+180D, age 1〜30 日, trade>=$300) は
# bot/cogs/sm_roster.py の定数で管理。 1 call=推定 5 credit。
SM_ROSTER_AUTO_ENABLED=true
# JST 何時何分に取得するか (HH:MM)
SM_ROSTER_FETCH_TIME_JST=00:30
# 自動取得結果のサマリ通知先 (空にすると通知なし、 DB には蓄積される)
SM_ROSTER_NOTIFY_CHANNEL_ID=
# roster の保持上限。 これを超えた分は last_seen が古い順に prune される。
# 0 以下にすると無制限 (Helius 上限を考えるとデフォの 500 推奨)。
SM_ROSTER_MAX_WALLETS=500

# Nansen /smart-money/dex-trades のフィルタ条件 (ソース変更不要で調整可)
SM_ROSTER_CHAIN=solana
# include / exclude はカンマ区切り。 ラベル候補:
#   Fund / Smart Trader / 30D Smart Trader / 90D Smart Trader /
#   180D Smart Trader / Smart HL Perps Trader
SM_ROSTER_INCLUDE_LABELS=Fund,180D Smart Trader
SM_ROSTER_EXCLUDE_LABELS=30D Smart Trader
# token_bought_age (日)。 仕込み対象の token の age を絞る。
SM_ROSTER_TOKEN_AGE_MIN=1
SM_ROSTER_TOKEN_AGE_MAX=30
# trade_value_usd 下限 (USD)。 ノイズ除去用。
SM_ROSTER_TRADE_VALUE_USD_MIN=200
# per_page (1〜1000)。 24h 全件で 500 程度あれば 1 call 完結することが多い。
SM_ROSTER_PER_PAGE=500

# === Nansen ===
NANSEN_API_KEY=your_nansen_api_key_here
NANSEN_BASE_URL=https://api.nansen.ai

# === Solana RPC (Deployer Trust 用、空なら public mainnet-beta) ===
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# === Helius (Deployer 強化: creator 取得 + creator の他 deploy 数) ===
# https://www.helius.dev/ で API key 取得
HELIUS_API_KEY=
# false にすると Helius 機能を完全に無効化 (key が空でも自動 OFF)
ENABLE_HELIUS=true

# === Helius Webhook (sm_roster の wallet を監視するための送信先設定) ===
# Helius が events を POST する宛先 URL。 例: https://your.host/helius-webhook
# 空のままだと /sm-helius-sync コマンドはエラー応答する。
HELIUS_WEBHOOK_URL=
# webhook 種別。 enhanced (パース済イベント) / raw (生 tx)。
HELIUS_WEBHOOK_TYPE=enhanced
# enhanced 時の対象 transaction type (カンマ区切り、 大文字)。
# 例: SWAP / TRANSFER / NFT_SALE / ...  raw 時は無視される。
HELIUS_WEBHOOK_TRANSACTION_TYPES=SWAP
# 受信側に渡す任意の認証ヘッダ値 (Authorization ヘッダの値など、 空ならヘッダ無し)。
HELIUS_WEBHOOK_AUTH_HEADER=
# 日次の SM roster 取得後に Helius webhook を自動 sync するか。
# 自動運用に入る前に false にして手動 /sm-helius-sync で挙動確認するのが推奨。
HELIUS_WEBHOOK_AUTO_SYNC=false

# === Helius Webhook 受信サーバ (bot プロセス内 aiohttp) ===
# Helius が POST してくる URL の bind 設定。 公開 URL は HELIUS_WEBHOOK_URL に
# (例: http://www.takmolts.mydns.jp:50150 なら BIND_PORT=50150)。
WEBHOOK_BIND_HOST=0.0.0.0
WEBHOOK_BIND_PORT=50150
WEBHOOK_PATH=/helius-webhook

# === SM Signal 通知 ===
# シグナルを投稿する Discord スレッド ID (空にすると通知無効、 ログのみ)。
SM_SIGNAL_THREAD_ID=
# SELL も通知するか。 false にすると BUY のみ通知。
SM_SIGNAL_INCLUDE_SELL=true
# 大口判定の閾値 (quote 単位そのまま、 USD 換算なし)。
SM_SIGNAL_LARGE_SOL_MIN=2.0
SM_SIGNAL_LARGE_STABLE_MIN=200.0
# 連発抑制ウィンドウ (分): 同 wallet × 同 mint × 同 direction を window 内は最初の 1 件のみ通知。
SM_SIGNAL_DEDUP_WINDOW_MIN=30
# 群衆判定ウィンドウ (分): 別 SM wallet が同 mint を window 内に取引していたら 🤝 ラベル。
SM_SIGNAL_GROUP_WINDOW_MIN=30

# === SM Summary (蓄積データから 2 段目絞り込みで毎時 Embed 通知) ===
# Nansen クレジットを消費せず、 sm_signal_events から集計してスコア順 TOP_N を投稿する。
SM_SUMMARY_ENABLED=true
# 集計対象期間 (分)。 毎正時 0 分にこの期間分を集計。
SM_SUMMARY_WINDOW_MIN=60
# 投稿の足切り。 「異なる SM wallet が BUY した数」 がこの値未満の mint は除外。
SM_SUMMARY_MIN_WALLETS=2
# Embed に出す mint の上限。
SM_SUMMARY_TOP_N=10
# 投稿先チャンネル。 空にすると DIGEST_CHANNEL_ID にフォールバック。
SM_SUMMARY_CHANNEL_ID=

# === SM Summary 速報 (event 駆動・ webhook 受信ごとの即時通知) ===
# sm_signal の BUY を見て、 ① 直近 window 内に min_buyers 以上の SM が同 mint を BUY、
# または ② 単発で whale 閾値超えの BUY、 を満たした時に SM_SUMMARY_CHANNEL_ID へ速報。
# 同 mint は cooldown 分は再通知抑制。 sm_signal の通常通知とは独立 (両方出る)。
SM_SUMMARY_REALTIME_ENABLED=true
# 群衆ブレイク判定の窓 (分)。
SM_SUMMARY_REALTIME_WINDOW_MIN=30
# 群衆ブレイクの distinct buyer 閾値 (今回の wallet を含む)。
SM_SUMMARY_REALTIME_MIN_BUYERS=3
# 単発 whale BUY の閾値 (quote 単位そのまま)。 sm_signal の 🐋 ラベル閾値より厳しめに。
SM_SUMMARY_REALTIME_WHALE_SOL_MIN=20.0
SM_SUMMARY_REALTIME_WHALE_STABLE_MIN=2000.0
# 同 mint の再通知抑制期間 (分)。
SM_SUMMARY_REALTIME_COOLDOWN_MIN=60

# === Dashboard publisher (SM 速報 BUY を別 git repo に push して GitHub Pages 公開) ===
# 別途 dashboard 用の public リポを clone した path を DASHBOARD_REPO_PATH に指定する。
# 詳しいセットアップは dashboard/README.md を参照。
DASHBOARD_PUBLISH_ENABLED=false
# 例: /home/<user>/dashboard-repo  (git clone 済み・ push 権限あり・ index.html 配置済み)
DASHBOARD_REPO_PATH=
# 何分間隔で集計 → push するか (最低 1 分。 git push が頻繁になりすぎない 5 分推奨)
DASHBOARD_PUBLISH_INTERVAL_MIN=5
# push 先ブランチ (Pages で公開しているブランチに合わせる)
DASHBOARD_GIT_BRANCH=main
# 集計時の足切り。 dashboard では sm_summary より緩めに 2 推奨。
DASHBOARD_MIN_DISTINCT_BUYERS=2
# 1 期間あたりに JSON に含める銘柄上限。
DASHBOARD_TOP_N=50
# 1 銘柄あたりに JSON に含める buyer 上限。
DASHBOARD_BUYERS_PER_TOKEN=30
# DexScreener で symbol/mcap を補完するか (false にすると JSON サイズ縮小・ 通信ゼロ)
DASHBOARD_ENRICH=true
# Pages で公開したダッシュボードのトップ URL (末尾 / 任意)。
# 設定すると速報 BUY の Discord 通知に「📊 dashboard」 Link ボタンが追加され、
# 押下時に <URL>?mint=<CA> 形式でその銘柄を自動選択した状態で開く。
DASHBOARD_PUBLIC_URL=

# === CoinGecko (Narrative の Trending 判定用、空でも動作するが Trending 機能無効化) ===
# Demo Plan のサインアップで取得可能 (10,000 call/月)
COINGECKO_API_KEY=
# false にすると CoinGecko 機能を完全に無効化
ENABLE_COINGECKO=true

# === ローカル LLM (rkllama / Ollama 互換、 オプショナル) ===
# 設定すると /analyze 結果の最後に LLM 総括コメント Embed を追加する
# LLM_HOST と LLM_MODEL の両方が空なら機能 skip
LLM_HOST=
LLM_MODEL=
LLM_NUM_CTX=4096
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_CONNECT=10
LLM_TIMEOUT_READ=300

# === Logging ===
LOG_LEVEL=INFO
